{
  "info": {
    "name": "PDF Merger API",
    "description": "End-to-end smoke flow for pdf-merger-api. Run with: newman run postman/collection.json --env-var baseUrl=http://localhost:8000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "tinyPdfB64", "value": "" }
  ],
  "item": [
    {
      "name": "1. Health check",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('has database field', () => pm.expect(body).to.have.property('database'));",
              "pm.test('has s3 field', () => pm.expect(body).to.have.property('s3'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2. Upload first PDF",
      "request": {
        "method": "POST",
        "url": { "raw": "{{baseUrl}}/api/v1/files", "host": ["{{baseUrl}}"], "path": ["api", "v1", "files"] },
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "file", "type": "file", "src": "./postman/sample.pdf" }
          ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Write the tiny PDF to disk if it doesn't exist (Newman runs in node).",
              "const fs = require('fs');",
              "const path = './postman/sample.pdf';",
              "if (!fs.existsSync(path)) {",
              "  const b64 = pm.collectionVariables.get('tinyPdfB64');",
              "  fs.writeFileSync(path, Buffer.from(b64, 'base64'));",
              "}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 201', () => pm.response.to.have.status(201));",
              "const body = pm.response.json();",
              "pm.expect(body.page_count).to.equal(1);",
              "pm.collectionVariables.set('fileId1', body.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "3. Upload second PDF",
      "request": {
        "method": "POST",
        "url": { "raw": "{{baseUrl}}/api/v1/files", "host": ["{{baseUrl}}"], "path": ["api", "v1", "files"] },
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "file", "type": "file", "src": "./postman/sample.pdf" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('fileId2', pm.response.json().id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "4. List uploaded files",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/api/v1/files", "host": ["{{baseUrl}}"], "path": ["api", "v1", "files"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('returns at least 2 files', () => pm.expect(body.total).to.be.at.least(2));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "5. Create merge job",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/v1/merge", "host": ["{{baseUrl}}"], "path": ["api", "v1", "merge"] },
        "body": {
          "mode": "raw",
          "raw": "{\"file_ids\":[\"{{fileId1}}\",\"{{fileId2}}\"]}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 202', () => pm.response.to.have.status(202));",
              "pm.collectionVariables.set('jobId', pm.response.json().id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "6. Poll job status",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/api/v1/jobs/{{jobId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "jobs", "{{jobId}}"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.expect(['pending','processing','completed']).to.include(body.status);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "7. Download merged PDF",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/api/v1/jobs/{{jobId}}/download", "host": ["{{baseUrl}}"], "path": ["api", "v1", "jobs", "{{jobId}}", "download"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200 or 409 (in progress)', () => pm.expect([200, 409]).to.include(pm.response.code));",
              "if (pm.response.code === 200) {",
              "  pm.test('content-type is pdf', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/pdf'));",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
