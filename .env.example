# Application
APP_NAME=pdf-merger-api
LOG_LEVEL=INFO
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+psycopg2://pdfuser:pdfpass@postgres:5432/pdfmerger

# S3 / LocalStack
S3_ENDPOINT_URL=http://localstack:4566
S3_BUCKET=pdf-merger
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Limits
MAX_UPLOAD_SIZE_MB=25
MAX_MERGE_FILES=20

# OpenTelemetry (bonus)
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=pdf-merger-api
